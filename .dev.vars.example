# ============================================================
# Local development bindings for `wrangler dev`
# ============================================================
# Copy this file to .dev.vars and fill in the values.
# .dev.vars is gitignored — never commit real credentials.
#
# Note: the neon-http driver speaks Neon's HTTP proxy protocol,
# so point DATABASE_URL at a Neon branch (create a free dev
# branch of the prod database), not at a local Postgres.
# ============================================================

NODE_ENV=development

# Neon dev-branch connection string
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# Comma-separated CORS origins; empty disables CORS (SSR needs none)
ALLOWED_ORIGINS=

# Optional: enables /api/__preview/post/:slug (draft preview for the
# frontend's draftMode). Min 16 chars. Production: `wrangler secret put PREVIEW_SECRET`
# PREVIEW_SECRET=
