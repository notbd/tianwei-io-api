# ---------------------------------------------------------------------------
# Environment Configuration Template
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values for local development.
# For production, set these variables via your deployment platform.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Runtime Environment
# ---------------------------------------------------------------------------
# Values: "development" | "production" | "test"
#
# - development: Loads .env.local, enables dev-only routes (/api/__dev/*)
# - production: No .env.local loading, expects platform-provided env vars
# - test: Used when running test scripts
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------

# Primary database connection string.
# This is what the running API server connects to.
#
# Local Docker (from tianwei-io-content repo):
#   postgresql://postgres:postgres@127.0.0.1:5431/tianwei_io_content_db
#
# Production (requires SSL):
#   postgresql://<user>:<password>@<host>.some-db.com/<database>?sslmode=require
DATABASE_URL=

# Remote database connection string.
# Optional - only used by test scripts to verify production DB connectivity.
# Leave empty if you don't need to test against the remote database locally.
#
# Format: postgresql://<user>:<password>@<host>.some-db.com/<database>?sslmode=require
DATABASE_URL_REMOTE=

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
# Port for the Hono server.
# - Local development: 3001 (avoids conflict with Next.js on 3000)
# - Production (Fly.io): Platform sets PORT automatically
PORT=3001

# ---------------------------------------------------------------------------
# CORS Configuration
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for cross-origin requests.
#
# CORS is a browser security feature that blocks client-side JavaScript
# from making requests to different domains unless explicitly allowed.
#
# If empty or omitted:
#   - CORS middleware is NOT applied
#   - Browser-based requests from other origins will be blocked
#   - Server-side requests (SSR) are unaffected
#
# If your Next.js frontend only fetches data during SSR (Server Components,
# getServerSideProps), you can leave this empty. However, setting it provides
# flexibility for future client-side features.
#
# Example for development + production:
#   http://localhost:3000,https://tianwei.io,https://www.tianwei.io
ALLOWED_ORIGINS=
